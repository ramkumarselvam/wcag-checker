{
  "name": "wcag-checker",
  "displayName": "WCAG 2.1 Checker",
  "version": "1.0.0",
  "description": "Chrome extension for automated WCAG 2.1 AA accessibility audits using axe-core",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "axe-core": "^4.9.1",
    "plasmo": "^0.89.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "sidePanel",
      "scripting",
      "storage"
    ]
  }
}
